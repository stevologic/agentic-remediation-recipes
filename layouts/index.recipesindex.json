{{- $docs := slice -}}
{{- $pages := where .Site.Pages "Kind" "in" (slice "page" "section") -}}
{{- range sort $pages "RelPermalink" -}}
  {{- $source := "" -}}
  {{- $slug := .Slug | default "" -}}
  {{- with .File }}
    {{- $source = .Path -}}
    {{- if and (eq $slug "") (ne .TranslationBaseName "_index") -}}
      {{- $slug = .TranslationBaseName -}}
    {{- end -}}
  {{- end -}}
  {{- if eq $slug "" -}}
    {{- $slug = replaceRE "/" "-" (replaceRE "^/|/$" "" .RelPermalink) -}}
  {{- end -}}
  {{- $docs = $docs | append (dict
    "slug" $slug
    "title" .Title
    "url" .Permalink
    "path" .RelPermalink
    "section" .Section
    "agent" (.Params.agent | default "general")
    "tags" (.Params.tags | default (slice))
    "severity" (.Params.severity | default "unspecified")
    "last_updated" (.Lastmod.Format "2006-01-02")
    "summary" (.Summary | plainify)
    "content" .Plain
    "source_file" $source
  ) -}}
{{- end -}}
{{- $docs | jsonify -}}
