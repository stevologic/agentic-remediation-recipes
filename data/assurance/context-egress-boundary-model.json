  "schema_version": "1.0",
  "last_reviewed": "2026-05-02",
  "intent": "Define the SecurityRecipes context egress boundary for agentic AI and MCP systems: every data class, destination class, workflow namespace, source trust tier, redaction requirement, residency constraint, and secret-egress kill rule is expressed as machine-readable policy before context leaves a tenant, model, MCP server, or observability boundary.",
  "positioning": {
    "buyer": "AI Platform, Security Engineering, Product Security, Privacy Engineering, GRC, procurement security, vendor-risk, and acquisition diligence teams",
    "category": "Secure context egress, residency, and data-boundary control for agentic AI",
    "enterprise_promise": "SecurityRecipes can prove not only which context an agent may retrieve, but also where that context may go, which controls must hold before egress, and which attempts must stop the session.",
    "why_now": "Agentic AI adoption is moving sensitive tickets, code, logs, tool outputs, and MCP connector results into model and tool contexts. Enterprise buyers need a deterministic data-boundary contract that maps public guidance, generated evidence, customer runtime data, secrets, residency, retention, and third-party MCP destinations."
  },
