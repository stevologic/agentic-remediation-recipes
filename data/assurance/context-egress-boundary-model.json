  "enterprise_adoption_packet": {
    "board_level_claim": "SecurityRecipes governs not only context retrieval, but context egress across model, MCP, tenant, telemetry, and third-party boundaries.",
    "default_questions_answered": [
      "Which data classes can leave a tenant-controlled MCP gateway?",
      "Which model providers, remote MCP servers, telemetry sinks, or public corpus destinations are allowed?",
      "Which requests hold for redaction, DPA, zero-data-retention, residency, or human approval evidence?",
      "Which context egress attempts should deny by default?",
      "Which secret or signing-material attempts kill the agent session?"
    ],
    "recommended_first_use": "Attach this pack to AI platform intake, remote MCP approval, model-provider review, privacy review, and customer trust-center evidence.",
    "sales_motion": "Lead with open data-boundary evidence, then sell tenant-side egress enforcement, provider policy adapters, residency alerts, DLP integrations, and trust-center exports."
  }
