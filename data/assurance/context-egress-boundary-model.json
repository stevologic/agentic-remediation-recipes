  "decision_contract": {
    "default_decision": "deny_unclassified_egress",
    "runtime_attributes": [
      "workflow_id",
      "source_id",
      "mcp_namespace",
      "data_class",
      "destination_class",
      "tenant_id",
      "destination_trust_tier",
      "contains_secret",
      "contains_unredacted_pii",
      "dpa_in_place",
      "zero_data_retention",
      "residency_region",
      "required_region",
      "human_approval_record",
      "egress_path"
    ],
    "decisions": [
      {
        "decision": "allow_public_egress_with_citation",
        "meaning": "Public or open SecurityRecipes context may leave the repo context layer when source ID, path, hash, and citation metadata are preserved."
      },
      {
        "decision": "allow_tenant_bound_egress",
        "meaning": "Tenant-sensitive context may leave one component only inside an approved tenant boundary with redaction, audit, retention, and residency controls satisfied."
      },
      {
        "decision": "hold_for_redaction_or_dpa",
        "meaning": "The request is plausible, but missing redaction, tenant ID, human approval, data-processing, zero-data-retention, or residency evidence."
      },
      {
        "decision": "deny_unapproved_workflow_egress",
        "meaning": "The workflow or MCP namespace is not approved for this context egress path."
      },
      {
        "decision": "deny_untrusted_destination",
        "meaning": "The destination is unknown, untrusted, disallowed for the data class, or not covered by required connector/provider controls."
      },
      {
        "decision": "deny_unclassified_egress",
        "meaning": "The data class or source is missing, unknown, or not mapped to a reviewed egress policy."
      },
      {
        "decision": "kill_session_on_secret_egress",
        "meaning": "Secrets, live tokens, private keys, signing material, seed phrases, or prohibited sensitive context attempted to leave the boundary."
      }
    ],
    "global_rules": [
      "Default-deny all context egress until the data class, destination class, workflow, and namespace are known.",
      "Public SecurityRecipes content may leave with citation and source-hash metadata; tenant runtime context may not be embedded in the open corpus.",
      "Customer source code, tickets, findings, logs, and pipeline evidence remain tenant-bound unless redaction, DPA, retention, and residency controls are satisfied.",
      "Remote MCP servers and model providers are treated as external processors unless explicitly approved for the tenant and data class.",
      "Secrets, private keys, signing material, seed phrases, and raw access tokens trigger kill-session behavior."
    ],
    "prohibited_data_classes": [
      "secret_or_token",
      "signing_material",
      "seed_phrase_or_private_key",
      "raw_access_token",
      "production_credential"
    ]
  },
