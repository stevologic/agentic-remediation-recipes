# DigitalOcean droplet / Docker Compose settings.
# Copy to .env on the droplet and edit values before `docker compose up -d --build`.
# If your droplet has the legacy Compose binary, use `docker-compose up -d --build`.

# Public site URL used by Hugo when it builds absolute links.
SECURITY_RECIPES_BASE_URL=https://security-recipes.ai/
SECURITY_RECIPES_REPO_URL=https://github.com/stevologic/security-recipes.ai
SECURITY_RECIPES_HTTP_PORT=80

# Chatbot model-provider credentials are not configured on the server.
# Users paste their own provider key in the browser; the nginx container
# proxies that one request through /ai-provider-proxy/* without storing it.

# Hosted MCP metadata and index source. Set these to your domain when forking.
RECIPES_MCP_SOURCE_INDEX_URL=https://security-recipes.ai/recipes-index.json
RECIPES_MCP_ALLOWED_SOURCE_HOSTS=security-recipes.ai
RECIPES_MCP_PUBLIC_BASE_URL=https://security-recipes.ai/mcp
RECIPES_MCP_LOG_LEVEL=info
RECIPES_MCP_EAGER_REFRESH=false
